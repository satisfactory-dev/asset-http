{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://satisfactory.dev/json-schema/asset-http/metadata.json",
	"type": "object",
	"required": ["Width", "Height", "SHA512", "Size"],
	"properties": {
		"Width": {
			"type": "integer",
			"minimum": 1
		},
		"Height": {
			"type": "integer",
			"minimum": 1
		},
		"SHA512": {
			"type": "string",
			"pattern": "^[a-f0-9]{128}$"
		},
		"Size": {
			"type": "integer",
			"minimum": 0
		}
	}
}
